      <aliases enabled='yes' />
      <column caption='Profit Margin' datatype='real' default-format='p0.00%' name='[Calculation_0710850768420866]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([profit]) / SUM([sales])' />
      </column>
      <column caption='Cost' datatype='real' name='[Calculation_0710850768527363]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[sales] - [profit]' />
      </column>
      <column caption='Average Order Value' datatype='real' name='[Calculation_0710850768568324]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([sales]) / COUNTD([order_id])' />
      </column>
      <column caption='Return Rate' datatype='real' default-format='p0.00%' name='[Calculation_0710850768642053]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([return_flag]) / COUNT([order_id])' />
      </column>
      <column caption='Shipping Delay Bucket' datatype='string' name='[Calculation_0710850768719878]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [delivery_days] &lt;= 1 THEN &quot;1 day or less&quot;&#13;&#10;ELSEIF [delivery_days] &lt;= 3 THEN &quot;2 to 3 days&quot;&#13;&#10;ELSEIF [delivery_days] &lt;= 5 THEN &quot;4 to 5 days&quot;&#13;&#10;ELSE &quot;More than 5 days&quot;&#13;&#10;END' />
      </column>
      <column caption='Region (copy)' datatype='string' name='[Region (copy)_0710850767659008]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[region]' />
      </column>
